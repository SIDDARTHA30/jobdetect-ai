# ═══════════════════════════════════════════════════════════
#  JOBDETECT v4.0 — Environment Configuration Template
#  Copy this to backend/.env and fill in your values
#  Generate SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
# ═══════════════════════════════════════════════════════════

APP_NAME=JOBDETECT
DEBUG=false
VERSION=4.0.0

# JWT — CHANGE THIS IN PRODUCTION
SECRET_KEY=generate-a-strong-secret-with-secrets-token-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=sqlite+aiosqlite:///./jobdetect.db

# ML Model
MODEL_PATH=./saved_models/job_classifier.pkl

# CORS — for single Render deploy, just add localhost for dev
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30
CLASSIFY_RATE_LIMIT=10

# Validation
MAX_TEXT_LENGTH=10000
MAX_TITLE_LENGTH=200
MIN_DESCRIPTION_LENGTH=10

# Confidence
CONFIDENCE_THRESHOLD=0.65
